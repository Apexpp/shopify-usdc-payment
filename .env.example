# Your USDC wallet address (where customers send payment)
USDC_WALLET_ADDRESS=0xYourWalletAddressHere

# Network to display to customers: ethereum | polygon | base
USDC_NETWORK=polygon

# Shopify store details
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxx

# Payment instructions timeout in minutes (shown on page)
PAYMENT_DEADLINE_HOURS=24

PORT=3000
